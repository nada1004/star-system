        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 26px;
        padding: 22px;
        overflow-y: auto;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
      }
      .b2-players-grid-wrapper::-webkit-scrollbar {
        width: 6px;
